      "item": [
        {
          "name": "Get data with correct \"id\"",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "",
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has title\", function () {",
                  "    pm.expect(res.title).to.be.a(\"string\").and.not.empty;",
                  "});",
                  "",
                  "pm.test(\"Response has body\", function () {",
                  "    pm.expect(res.body).to.be.a(\"string\").and.not.empty;",
                  "});",
                  "",
                  "pm.test(\"Response has userId\", function () {",
                  "    pm.expect(res.userId).to.exist;",
                  "});",
                  "",
                  "pm.test(\"Response has id\", function () {",
                  "    pm.expect(res.id).to.exist;",
                  "});",
                  "",
                  "pm.test(\"Response time is less than 200ms\", function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(200);",
                  "});",
                  "",
                  "pm.test(\"userId is an integer\", function () {",
                  "    pm.expect(Number.isInteger(res.userId)).to.be.true;",
                  "});",
                  "",
                  "pm.test(\"id is an integer\", function () {",
                  "    pm.expect(Number.isInteger(res.id)).to.be.true;",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
